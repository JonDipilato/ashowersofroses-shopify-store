<section class="section-shell vip-hero">
  <div class="page-width vip-hero__inner">
    <p class="section-kicker">Monthly Rose Society</p>
    <h1 class="section-heading vip-hero__title">Curated Grace,<br>Delivered to Your Door</h1>
    <p class="section-subhead vip-hero__sub">
      Patricia personally selects and ships each box from home — handpicked sacramentals, seasonal devotionals, and small-batch gifts rooted in faith. Join the list and receive yours monthly.
    </p>
    <a href="#vip-form" class="btn btn-primary vip-hero__cta">Join the Society — It's Free to Sign Up</a>
  </div>
</section>

<section class="section-shell packages-section">
  <div class="page-width">
    <p class="section-kicker">Choose Your Box</p>
    <h2 class="section-heading">Three Ways to Receive Grace Monthly</h2>
    <p class="section-subhead">Each box is assembled by Patricia herself. No warehouse. No automation. Just a devoted Catholic woman curating for your family.</p>

    <div class="packages-grid" style="margin-top: 2.5rem;">

      <div class="package-card package-card--rose">
        <div class="package-card__badge">Most Popular</div>
        <div class="package-card__icon">&#10022;</div>
        <h3 class="package-card__name">The Rose Garden</h3>
        <p class="package-card__price">$35 <span>/month</span></p>
        <ul class="package-card__list">
          <li>Curated rosary meditation card</li>
          <li>Saint feast day calendar insert</li>
          <li>Hand-tied dried roses from the shop</li>
          <li>Seasonal holy card</li>
          <li>Personal blessing note from Patricia</li>
        </ul>
        <a href="#vip-form" class="btn btn-secondary pkg-btn">Sign Up Below</a>
      </div>

      <div class="package-card package-card--sanctuary package-card--featured">
        <div class="package-card__badge package-card__badge--gold">Best Value</div>
        <div class="package-card__icon">&#10014;</div>
        <h3 class="package-card__name">The Sanctuary Box</h3>
        <p class="package-card__price">$65 <span>/month</span></p>
        <ul class="package-card__list">
          <li>Everything in The Rose Garden</li>
          <li>Handmade rosary or sacramental</li>
          <li>Liturgical candle</li>
          <li>Seasonal holy card set (4 cards)</li>
          <li>Exclusive member discount code</li>
        </ul>
        <a href="#vip-form" class="btn btn-primary pkg-btn">Sign Up Below</a>
      </div>

      <div class="package-card package-card--bridal">
        <div class="package-card__badge package-card__badge--rose">Premium</div>
        <div class="package-card__icon">&#10024;</div>
        <h3 class="package-card__name">The Bridal Rose</h3>
        <p class="package-card__price">$95 <span>/month</span></p>
        <ul class="package-card__list">
          <li>Everything in The Sanctuary Box</li>
          <li>Full custom sacramental collection</li>
          <li>Priority early access to new arrivals</li>
          <li>Hand-written note + prayer intention</li>
          <li>Surprise exclusive gift each month</li>
        </ul>
        <a href="#vip-form" class="btn btn-secondary pkg-btn">Sign Up Below</a>
      </div>

    </div>
  </div>
</section>

<section class="section-shell form-section" id="vip-form">
  <div class="page-width form-section__inner">

    <div class="form-section__left">
      <p class="section-kicker">Reserve Your Spot</p>
      <h2 class="section-heading form-section__title">Join the Monthly<br>Rose Society</h2>
      <p class="form-section__body">
        Patricia reaches out personally via <strong>text and email</strong> once you're on the list. Your information is never shared. This is a private community of Catholic families who love intentional gifting.
      </p>
      <ul class="form-section__perks">
        <li>&#10003;&nbsp; SMS updates on your monthly box</li>
        <li>&#10003;&nbsp; Email previews before each shipment</li>
        <li>&#10003;&nbsp; Early access to limited sacramentals</li>
        <li>&#10003;&nbsp; Direct line to Patricia for custom requests</li>
      </ul>

      <div class="qr-wrap">
        <p class="qr-wrap__label">Scan to share with a friend</p>
        <div class="qr-frame">
          <img
            src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&color=8A2034&bgcolor=FBF7F0&margin=10&data={{ shop.url | append: '/pages/join' | url_encode }}"
            alt="QR code to join the Monthly Rose Society"
            width="180"
            height="180"
            class="qr-img"
          >
          <p class="qr-frame__name">{{ shop.name }}</p>
        </div>
      </div>
    </div>

    <div class="form-section__right">
      <div class="ghl-form-wrap">
        <iframe
          src="https://api.leadconnectorhq.com/widget/form/JHl1KW43Ovv3cpcn7bYj"
          style="width:100%;height:668px;border:none;border-radius:3px"
          id="inline-JHl1KW43Ovv3cpcn7bYj"
          data-layout="{'id':'INLINE'}"
          data-trigger-type="alwaysShow"
          data-trigger-value=""
          data-activation-type="alwaysActivated"
          data-activation-value=""
          data-deactivation-type="neverDeactivate"
          data-deactivation-value=""
          data-form-name="Form 0"
          data-height="668"
          data-layout-iframe-id="inline-JHl1KW43Ovv3cpcn7bYj"
          data-form-id="JHl1KW43Ovv3cpcn7bYj"
          title="Join the Monthly Rose Society"
          loading="lazy"
        ></iframe>
        <script src="https://link.msgsndr.com/js/form_embed.js"></script>
      </div>
    </div>

  </div>
</section>

<style>
  /* ── VIP Hero ── */
  .vip-hero {
    text-align: center;
    background: radial-gradient(ellipse at 50% 0%, rgba(138,32,52,0.07) 0%, transparent 70%);
    border-bottom: 1px solid rgba(183,157,97,0.18);
  }
  .vip-hero__inner { max-width: 720px; }
  .vip-hero__title { color: var(--color-rose); margin-top: 0.6rem; }
  .vip-hero__sub { margin: 1.2rem auto 2rem; max-width: 54ch; font-size: 1.05rem; }
  .vip-hero__cta { font-size: 1rem; padding: 0.85rem 2rem; letter-spacing: 0.04em; }

  /* ── Packages ── */
  .packages-section { background: transparent; }
  .packages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    align-items: start;
  }
  .package-card {
    position: relative;
    background: var(--color-surface, rgba(255,255,255,0.55));
    border: 1px solid rgba(183,157,97,0.22);
    border-radius: var(--radius-soft);
    padding: 2rem 1.75rem 1.75rem;
    backdrop-filter: blur(8px);
    transition: box-shadow 0.25s, transform 0.25s;
  }
  .package-card:hover {
    box-shadow: 0 12px 40px rgba(138,32,52,0.12);
    transform: translateY(-4px);
  }
  .package-card--featured {
    border-color: rgba(183,157,97,0.55);
    box-shadow: 0 4px 24px rgba(138,32,52,0.10);
  }
  .package-card__badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-botanical, #3a5c3e);
    color: #fff;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.3rem 0.9rem;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }
  .package-card__badge--gold { background: var(--color-gold, #b79d61); color: var(--color-ink, #1a1a1a); }
  .package-card__badge--rose { background: var(--color-rose, #8a2034); }
  .package-card__icon {
    font-size: 1.4rem;
    color: var(--color-gold, #b79d61);
    margin-bottom: 0.6rem;
  }
  .package-card__name {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
    color: var(--color-ink);
  }
  .package-card__price {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-rose, #8a2034);
    margin: 0 0 1.2rem;
  }
  .package-card__price span {
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--color-muted, #777);
    font-family: var(--font-body);
  }
  .package-card__list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--color-ink) 80%, transparent);
  }
  .package-card__list li::before {
    content: "✦ ";
    color: var(--color-gold, #b79d61);
    font-size: 0.7rem;
  }
  .pkg-btn { width: 100%; text-align: center; justify-content: center; }

  /* ── Form Section ── */
  .form-section {
    background: radial-gradient(ellipse at 0% 50%, rgba(183,157,97,0.06), transparent 60%),
                radial-gradient(ellipse at 100% 50%, rgba(138,32,52,0.06), transparent 60%);
    border-top: 1px solid rgba(183,157,97,0.18);
  }
  .form-section__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .form-section__title { margin-top: 0.6rem; }
  .form-section__body { margin: 1rem 0 1.5rem; font-size: 0.97rem; line-height: 1.7; max-width: 44ch; }
  .form-section__perks {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 0.92rem;
    color: color-mix(in srgb, var(--color-ink) 82%, transparent);
  }

  /* ── QR Code ── */
  .qr-wrap { }
  .qr-wrap__label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-muted, #777);
    margin-bottom: 0.75rem;
  }
  .qr-frame {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    background: var(--color-ivory, #fbf7f0);
    border: 1.5px solid rgba(183,157,97,0.45);
    border-radius: var(--radius-soft);
    padding: 1.1rem 1.25rem;
    box-shadow: 0 4px 20px rgba(138,32,52,0.08);
  }
  .qr-img { border-radius: 6px; }
  .qr-frame__name {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-rose, #8a2034);
    letter-spacing: 0.06em;
    margin: 0;
  }

  /* ── GHL Form Wrapper ── */
  .ghl-form-wrap {
    background: var(--color-surface, rgba(255,255,255,0.55));
    border: 1px solid rgba(183,157,97,0.25);
    border-radius: var(--radius-soft);
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(138,32,52,0.09);
    backdrop-filter: blur(8px);
  }

  /* ── Responsive ── */
  @media (max-width: 820px) {
    .form-section__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .packages-grid { grid-template-columns: 1fr; }
    .vip-hero__title { font-size: clamp(1.8rem, 8vw, 3rem); }
  }
</style>

{% schema %}
{
  "name": "Monthly Rose Society Signup",
  "settings": [],
  "presets": [
    { "name": "Monthly Rose Society Signup" }
  ]
}
{% endschema %}
